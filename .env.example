# ── Option A: Direct Anthropic API ───────────────────────────────────────────
# Get an API key at console.anthropic.com (add credits separately from Pro sub)
ANTHROPIC_API_KEY=your_key_here

# ── Option B: Hermes gateway (uses your claude_code OAuth / Pro subscription) ─
# 1. Start the gateway:  hermes gateway run
# 2. Set these two vars and leave ANTHROPIC_API_KEY blank
HERMES_API_KEY=crag-poc-local
HERMES_BASE_URL=http://localhost:8642/v1

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGSMITH_API_KEY=your_key_here
LANGSMITH_PROJECT=crag-poc-dutch-tax
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=crag-poc-dutch-tax
